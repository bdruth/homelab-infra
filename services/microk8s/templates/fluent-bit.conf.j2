[SERVICE]
    Flush         5
    Daemon        Off
    Log_Level     INFO
    Parsers_File  parsers.conf
    HTTP_Server   On
    HTTP_Listen   0.0.0.0
    HTTP_Port     2020

[INPUT]
    Name              tail
    Path              /var/log/containers/*.log
    Exclude_Path      /var/log/containers/fluent-bit*.log
    Parser            containerd_plain
    Tag               kube.*
    Mem_Buf_Limit     5MB
    Skip_Long_Lines   On

[INPUT]
    Name              systemd
    Tag               host.*
    Systemd_Filter    _SYSTEMD_UNIT=kubelet.service
    Systemd_Filter    _SYSTEMD_UNIT=containerd.service
    Systemd_Filter    _SYSTEMD_UNIT=snap.microk8s.daemon-apiserver.service
    Systemd_Filter    _SYSTEMD_UNIT=snap.microk8s.daemon-controller-manager.service
    Systemd_Filter    _SYSTEMD_UNIT=snap.microk8s.daemon-scheduler.service
    Systemd_Filter    _SYSTEMD_UNIT=snap.microk8s.daemon-proxy.service
    Systemd_Filter    _SYSTEMD_UNIT=snap.microk8s.daemon-etcd.service
    Read_From_Tail    On

[FILTER]
    Name              kubernetes
    Match             kube.*
    Kube_URL          https://kubernetes.default.svc:443
    Kube_CA_File      /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
    Kube_Token_File   /var/run/secrets/kubernetes.io/serviceaccount/token
    Kube_Tag_Prefix   kube.var.log.containers.

[FILTER]
    Name          nest
    Match         kube.*
    Operation     lift
    Nested_under  kubernetes
    Add_prefix    kubernetes_

[OUTPUT]
    Name                gelf
    Match               kube.*
    Host                {{ microk8s_fluentbit_gelf_host }}
    Port                {{ microk8s_fluentbit_gelf_port }}
    Mode                tcp
    Gelf_Short_Message_Key log

[OUTPUT]
    Name                gelf
    Match               host.*
    Host                {{ microk8s_fluentbit_gelf_host }}
    Port                {{ microk8s_fluentbit_gelf_port }}
    Mode                tcp
    Gelf_Short_Message_Key message
