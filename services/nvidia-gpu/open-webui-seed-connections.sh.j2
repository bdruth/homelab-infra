#!/usr/bin/env bash
# Seeds Open WebUI's OpenAI connection list after the container starts.
# Generated by the nvidia-gpu Ansible role.
#
# Required because Open WebUI's env-var-only seed mode
# (ENABLE_PERSISTENT_CONFIG=false) resets the in-DB connection config on every
# container start, but OPENAI_API_CONFIGS (per-connection api_type, model_ids)
# has no env-var equivalent. Run from the systemd unit's ExecStartPost so the
# config is re-applied on every container start (Ansible re-deploys, manual
# `systemctl restart`, host reboots, etc.).

set -u
PORT="{{ open_webui_port }}"
TOKEN_FILE="/etc/open-webui/admin-token"
PAYLOAD_FILE="/etc/open-webui/connections.json"
TAG="open-webui-seed"

if [ ! -s "$TOKEN_FILE" ] || [ ! -s "$PAYLOAD_FILE" ]; then
    echo "$TAG: token or payload missing, skipping"
    exit 0
fi

TOKEN="$(cat "$TOKEN_FILE")"

# Wait for /ready up to 5 minutes (covers Playwright/Chromium install on cold
# starts plus FastAPI startup hooks).
for _ in $(seq 1 60); do
    if curl -fsS -m 5 "http://127.0.0.1:${PORT}/ready" >/dev/null 2>&1; then
        break
    fi
    sleep 5
done

if ! curl -fsS -m 5 "http://127.0.0.1:${PORT}/ready" >/dev/null 2>&1; then
    echo "$TAG: /ready never returned 200, giving up" >&2
    exit 0
fi

OUT="$(mktemp)"
trap 'rm -f "$OUT"' EXIT

HTTP_CODE=$(curl -sS -m 15 -o "$OUT" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Type: application/json" \
    -X POST --data "@${PAYLOAD_FILE}" \
    "http://127.0.0.1:${PORT}/openai/config/update" \
    -w "%{http_code}")

if [ "$HTTP_CODE" = "200" ]; then
    echo "$TAG: connection config applied"
else
    echo "$TAG: POST returned HTTP $HTTP_CODE" >&2
    head -c 500 "$OUT" >&2 || true
fi

# Always exit 0 so a transient OWUI hiccup (or upstream API change) doesn't
# fail the systemd unit. Failures still appear in the journal.
exit 0
